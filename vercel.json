{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/news/:id",
      "destination": "/news-style.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*).(ttf|png|js)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; frame-ancestors 'none';"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/news-style.html",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
