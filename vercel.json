{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/news-style",
      "destination": "/404",
      "permanent": false
    },
    {
      "source": "/news-style/:path*",
      "destination": "/404",
      "permanent": false
    },
    {
      "source": "/archive/index",
      "destination": "/archive",
      "permanent": true
    },
    {
      "source": "/archive/:slug",
      "destination": "/archive?page=:slug",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/news/:id",
      "destination": "/news-style"
    },
    {
      "source": "/archive/assets/:path*",
      "destination": "/archive/assets/:path*"
    },
    {
      "source": "/archive/:slug.md",
      "destination": "/archive/:slug.md"
    },
    {
      "source": "/archive",
      "destination": "/archive/index.html"
    },
    {
      "source": "/archive/:path*",
      "destination": "/archive/index.html"
    }
  ]
}
