{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/wiki/wiki-global.js",
      "destination": "/wiki/wiki-global.js"
    },
    {
      "source": "/wiki/articles/:path*",
      "destination": "/wiki/articles/:path*"
    },
    {
      "source": "/news/:id",
      "destination": "/news-style"
    },
    {
      "source": "/wiki",
      "destination": "/wiki/index.html"
    },
    {
      "source": "/wiki/:path*",
      "destination": "/wiki/index.html"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "wiki.kaeront.ru"
        }
      ],
      "destination": "/wiki/index.html"
    }
  ]
}
