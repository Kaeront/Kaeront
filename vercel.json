{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/news-style",
      "destination": "/404",
      "permanent": false
    },
    {
      "source": "/news-style/:path*",
      "destination": "/404",
      "permanent": false
    },
    /* Красиво перекидываем /archive/index на чистый /archive */
    {
      "source": "/archive/index",
      "destination": "/archive",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/news/:id",
      "destination": "/news-style"
    },
    /* Разрешаем прямой доступ к системным файлам архива */
    {
      "source": "/archive/assets/:path*",
      "destination": "/archive/assets/:path*"
    },
    {
      "source": "/archive/:slug.md",
      "destination": "/archive/:slug.md"
    },
    /* Любые запросы к /archive или /archive/что-угодно отдают единый index.html */
    {
      "source": "/archive",
      "destination": "/archive/index.html"
    },
    {
      "source": "/archive/:path*",
      "destination": "/archive/index.html"
    }
  ]
}