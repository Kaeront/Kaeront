{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/news/:id",
      "destination": "/news-style.html"
    },
    {
      "source": "/(.*).png",
      "destination": "/404.html"
    },
    {
      "source": "/(.*).ttf",
      "destination": "/404.html"
    },
    {
      "source": "/global.js",
      "destination": "/404.html"
    },
    {
      "source": "/news-style.html",
      "destination": "/404.html"
    }
  ]
}
