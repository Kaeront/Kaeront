{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/news/:id",
      "destination": "/news-style.html"
    }
  ],
  "headers": [
    {
      "source": "/news-style.html",
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'none';" }
      ]
    }
  ]
}
