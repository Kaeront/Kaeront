{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/news/:id",
      "destination": "/news-style"
    },
    {
      "source": "/wiki-global.js",
      "has": [{ "type": "host", "value": "wiki.kaeront.ru" }],
      "destination": "/wiki/wiki-global.js"
    },
    {
      "source": "/articles/:path*",
      "has": [{ "type": "host", "value": "wiki.kaeront.ru" }],
      "destination": "/wiki/articles/:path*"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "wiki.kaeront.ru" }],
      "destination": "/wiki/index.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "wiki.kaeront.ru" }],
      "destination": "/wiki/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/wiki",
      "destination": "/404",
      "permanent": false
    },
    {
      "source": "/wiki/:path*",
      "destination": "/404",
      "permanent": false
    },
    {
      "source": "/news-style",
      "destination": "/404",
      "permanent": false
    },
    {
      "source": "/news-style/:path*",
      "destination": "/404",
      "permanent": false
    }
  ]
}
