{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/archive",
      "destination": "/404",
      "permanent": false
    },
    {
      "source": "/archive/:path*",
      "destination": "/404",
      "permanent": false
    },
    {
      "source": "/wiki",
      "destination": "/404",
      "permanent": false
    },
    {
      "source": "/wiki/:path*",
      "destination": "/404",
      "permanent": false
    },
    {
      "source": "/news-style",
      "destination": "/404",
      "permanent": false
    },
    {
      "source": "/news-style/:path*",
      "destination": "/404",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/news/:id",
      "destination": "/news-style"
    },
    {
      "source": "/wiki-global.js",
      "has": [{ "type": "host", "value": "archive.kaeront.ru" }],
      "destination": "/archive/wiki-global.js"
    },
    {
      "source": "/:slug.md",
      "has": [{ "type": "host", "value": "archive.kaeront.ru" }],
      "destination": "/archive/:slug.md"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "archive.kaeront.ru" }],
      "destination": "/archive/index.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "archive.kaeront.ru" }],
      "destination": "/archive/index.html"
    }
  ]
}
