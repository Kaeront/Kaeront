{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/news/:id", "destination": "/news-style" },
    { "source": "/minecraft.ttf", "destination": "/404" },
    { "source": "/*.png", "destination": "/404" },
    { "source": "/*.js", "destination": "/404" },
    { "source": "/*.json", "destination": "/404" },
    { "source": "/news-style.html", "destination": "/404" }
  ]
}
