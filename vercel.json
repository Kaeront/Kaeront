{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/(.*).png",
      "destination": "/404",
      "permanent": false
    },
    {
      "source": "/news-style.html",
      "destination": "/404",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/news/:id",
      "destination": "/news-style.html"
    }
  ]
}
